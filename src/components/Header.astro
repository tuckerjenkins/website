---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const { lang = 'en' } = Astro.props;
const isSv = lang === 'sv';

const links = isSv
	? [
		{ href: '/sv', label: 'Introduktion' },
		{ href: '/sv/advisory', label: 'Rådgivning' },
		{ href: 'https://substack.com/@jamesj322928', label: 'Blogg', external: true },
		{ href: '/sv/contact', label: 'Kontakt' },
	]
	: [
		{ href: '/', label: 'Introduction' },
		{ href: '/advisory', label: 'Advisory' },
		{ href: 'https://substack.com/@jamesj322928', label: 'Blog', external: true },
		{ href: '/contact', label: 'Contact' },
	];

const currentPath = Astro.url.pathname;
const enPath = currentPath.replace(/^\/sv/, '') || '/';
const svPath = currentPath.startsWith('/sv') ? currentPath : `/sv${currentPath === '/' ? '' : currentPath}`;
---

<header>
	<nav>
		<h2><a href={isSv ? '/sv' : '/'}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			{links.map(link =>
				link.external
					? <a href={link.href} target="_blank">{link.label}</a>
					: <HeaderLink href={link.href}>{link.label}</HeaderLink>
			)}
		</div>
		<div class="social-links">
			<a href="https://www.linkedin.com/in/jamesgjenkins/" target="_blank">
				<span class="sr-only">James on LinkedIn</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"><path fill="currentColor" d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/></svg>
			</a>
			<a href="mailto:James.george.jenkins@gmail.com">
				<span class="sr-only">Email James</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"><path fill="currentColor" d="M1.5 3h13A1.5 1.5 0 0 1 16 4.5v7A1.5 1.5 0 0 1 14.5 13h-13A1.5 1.5 0 0 1 0 11.5v-7A1.5 1.5 0 0 1 1.5 3zm0 1a.5.5 0 0 0-.5.5v.217l7 4.2 7-4.2V4.5a.5.5 0 0 0-.5-.5h-13zM15 6.383l-4.708 2.825L15 11.105V6.383zm-.034 5.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A.5.5 0 0 0 1.5 12h13a.5.5 0 0 0 .466-.741zM1 11.105l4.708-1.897L1 6.383v4.722z"/></svg>
			</a>
		</div>
		<div class="lang-toggle">
			{isSv
				? <a href={enPath}>EN</a>
				: <a href={svPath}>SV</a>
			}
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgb(var(--bg));
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: rgb(var(--black));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--gray-dark));
		border-bottom: 4px solid transparent;
		text-decoration: none;
		font-size: 0.9em;
	}
	nav a:hover {
		color: rgb(var(--black));
	}
	nav a.active {
		text-decoration: none;
		color: rgb(var(--black));
		border-bottom-color: var(--accent);
	}
	.lang-toggle a {
		font-size: 0.8em;
		letter-spacing: 0.05em;
		color: rgb(var(--gray));
		border: 1px solid rgb(var(--gray-light));
		border-radius: 4px;
		padding: 0.3em 0.6em;
	}
	.lang-toggle a:hover {
		color: rgb(var(--black));
		border-color: rgb(var(--gray-dark));
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
