---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>James Jenkins</h1>
			<p>
				I build and lead businesses where technology, creativity and commercial growth
				meet. Group CEO of Forsman &amp; Bodenfors. Twenty years and four cities &mdash; London,
				San Francisco, New York, now Stockholm.
			</p>
			<p>
				I move early, stay curious, and build advantage through innovation. I care about
				the people I work with, and I think strong communication and a real work ethic are
				what turn strategy into momentum. We get one go at this &mdash; so we might as well build
				something great and enjoy it.
			</p>
		</main>
		<Footer />
	</body>
</html>